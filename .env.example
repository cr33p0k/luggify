# OpenWeatherMap API ключ (получить на https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# URL базы данных (для Docker используется автоматически из docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://luggify:luggify@localhost:5432/luggify_db

# OpenTripMap API ключ (получить на https://opentripmap.io/register)
OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here

# Travelpayouts API токен (получить на https://travelpayouts.com)
# Используется для поиска авиабилетов и отелей
TRAVELPAYOUTS_TOKEN=your_travelpayouts_token_here

# RapidAPI ключ (получить на https://rapidapi.com)
# Используется для поиска отелей через Booking.com (booking-com18)
RAPIDAPI_KEY=your_rapidapi_key_here

# Gemini / AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=luggify_bot
TELEGRAM_MINI_APP_URL=https://your-mini-app-url.example.com
TELEGRAM_AUTH_MAX_AGE=86400
ALLOW_INSECURE_TELEGRAM_AUTH=false
VITE_TELEGRAM_BOT_USERNAME=luggify_bot
