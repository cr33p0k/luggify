APP_DOMAIN=example.com
APP_WWW_DOMAIN=www.example.com
API_DOMAIN=api.example.com
PUBLIC_API_URL=https://api.example.com
ACME_EMAIL=you@example.com

POSTGRES_DB=luggify_db
POSTGRES_USER=luggify
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql+asyncpg://luggify:change-this-password@db:5432/luggify_db

CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com
SECRET_KEY=change-this-secret-key-to-a-long-random-string

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-mail@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-mail@example.com
